  "description": "DAO Voting System — Blockchain Governance Platform cho cổ đông",
  "author": "Đồ án sinh viên",
  "license": "MIT",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:gas": "REPORT_GAS=true hardhat test",
    "test:token": "hardhat test test/HSTToken.test.js",
    "test:gov": "hardhat test test/Governance.test.js",
    "coverage": "hardhat coverage",
    "deploy:local": "hardhat run scripts/setup_demo.js --network hardhat",
    "deploy:ganache": "hardhat run scripts/setup_demo.js --network ganache",
    "deploy:amoy": "hardhat run scripts/setup_demo.js --network amoy",
    "node": "hardhat node",
    "clean": "hardhat clean",
